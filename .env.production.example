# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_* are read directly by the postgres container
# DATABASE_URL must use the compose service name "db" as host
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=portfolio
DATABASE_URL=postgresql://portfolio:change_me_strong_password@db:5432/portfolio

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Used for image uploads (avatar, project covers, etc.)
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# SUPABASE_SECRET_KEY=your-secret-key  # only if needed for server-side operations

# ── Container registry ────────────────────────────────────────────────────────
# Image name is hardcoded in docker-compose.prod.yml — no variable needed here
