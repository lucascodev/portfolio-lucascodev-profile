# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Must match POSTGRES_* below — host is the compose service name "db"
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@db:5432/DB_NAME

DB_USER=portfolio
DB_PASSWORD=change_me_strong_password
DB_NAME=portfolio

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# ── Container registry ────────────────────────────────────────────────────────
# GitHub repository slug (e.g. lucascodev/portfolio-lucascodev-profile)
GITHUB_REPOSITORY=lucascodev/portfolio-lucascodev-profile
IMAGE_TAG=latest
